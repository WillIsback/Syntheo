{
  "name": "syntheo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "node --import tsx --test src/**/*.test.ts 'src/app/api/sessions/*/status/*.test.ts' 'src/app/api/sessions/*/route.test.ts' 'src/app/api/sessions/*/speakers/*.test.ts' 'src/app/api/transcribe/**/*.test.ts' src/**/*.test.tsx src/**/*.test.js",
    "lint": "biome check",
    "format": "biome format --write",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "db:down": "docker compose -f docker-compose.db.yml down",
    "db:init": "docker compose -f docker-compose.db.yml exec -T postgres sh -c 'until pg_isready -U syntheo -d syntheo >/dev/null 2>&1; do sleep 1; done; psql -U syntheo -d syntheo' < db/init/001_auth.sql",
    "db:seed-user": "node --env-file=.env scripts/seed-dev-user.mjs",
    "db:seed": "node --env-file=.env scripts/seed-dev-user.mjs && node --env-file=.env scripts/seed-dev-sessions.mjs",
    "db:seed-users": "node --env-file=.env scripts/seed-users.mjs",
    "db:seed-mock-sessions": "node --env-file=.env scripts/seed-mock-sessions.mjs",
    "db:migrate": "drizzle-kit migrate",
    "db:drizzle:generate": "drizzle-kit generate",
    "db:drizzle:migrate": "drizzle-kit migrate",
    "db:drizzle:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.10",
    "@aws-sdk/client-s3": "^3.1089.0",
    "@aws-sdk/s3-request-presigner": "^3.1089.0",
    "ai": "^7.0.28",
    "bcryptjs": "^3.0.3",
    "docx": "^9.7.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
